# ─── Supabase ────────────────────────────────────────────────────────────────
# Seguro expor no frontend — protegido por Row Level Security (RLS)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# ─── OpenRouter (IA) ──────────────────────────────────────────────────────────
# NUNCA use o prefixo NEXT_PUBLIC_ aqui — esta chave só existe no servidor
OPENROUTER_API_KEY=sk-or-v1-sua-chave-aqui
